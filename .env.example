# Anthropic — get from console.anthropic.com
# Phase 1–3 (local): user enters key in the app UI; stored in the settings table.
# Phase 5: route through the backend so the key never ships in the browser bundle.
VITE_ANTHROPIC_API_KEY=

# Phase 4 backend (server/). Optional in dev (falls back to a dev secret).
# Set a long random value in any real deployment — it signs session cookies.
SESSION_SECRET=
# Override the SQLite file location if desired (default: server/data/daybook.db).
# DAYBOOK_DB_PATH=

# Supabase — Phase 6 only. Leave blank until Phase 6.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
